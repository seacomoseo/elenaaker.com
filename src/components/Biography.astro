---
import { translations, Language } from '../translations';
import { ASSETS } from '../constants';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = translations[lang].bio;
const isProd = import.meta.env.PROD;
const getResponsiveSrcSet = (url: string, widths: number[], originalWidth: number) =>
  widths
    .filter((width) => width < originalWidth)
    .map((width) => `${url.replace(/\.jpg$/, `-${width}.jpg`)} ${width}w`)
    .concat(`${url} ${originalWidth}w`)
    .join(', ');

const bioSections = [
  {
    heading: lang === Language.ES ? 'Trayectoria como Arpista' : 'Career as Harpist',
    text: t.extendedCareer,
    photo: ASSETS.photos[2],
  },
  {
    heading: lang === Language.ES ? 'Hitos Destacados' : 'Career Highlights',
    text: t.extendedHighlights,
    photo: ASSETS.photos[3],
  },
  {
    heading: lang === Language.ES ? 'Composición y Producción' : 'Composition & Production',
    text: t.extendedComposition,
    photo: ASSETS.photos[4],
  },
  {
    heading: lang === Language.ES ? 'Hospitalidad de Lujo' : 'Luxury Hospitality',
    text: t.extendedHospitality,
    photo: ASSETS.photos[9],
  },
  {
    heading: lang === Language.ES ? 'Trayectoria Vocal y Visión Artística' : 'Vocal Career & Artistic Vision',
    text: t.extendedSinger + '\n\n' + t.extendedVision,
    photo: ASSETS.photos[8],
  },
  {
    heading: lang === Language.ES ? 'Legado Educativo' : 'Educational Legacy',
    text: t.extendedLegacy,
    photo: ASSETS.photos[5],
  },
];
---

<section id="bio" class="deferred-section py-24 md:py-32 px-6 md:px-24 bg-[#0a0a0a]">
  {/* Main Bio */}
  <div class="max-w-6xl mx-auto grid lg:grid-cols-5 gap-16 lg:gap-20 items-stretch mb-20 md:mb-28">
    <div class="lg:col-span-3">
      <span class="text-[11px] font-bold uppercase tracking-[0.4em] text-[#c5a059] mb-4 block">{t.sectionLabel}</span>
      <h2 class="text-4xl md:text-5xl font-display font-light mb-4">{t.title}</h2>
      <p class="text-[11px] uppercase tracking-[0.3em] text-gray-400 mb-10 font-subtitle italic">{t.stageName}</p>
      <div class="space-y-6 text-gray-400 leading-relaxed font-light text-base md:text-lg bio-text">
        {t.summary.split('\n\n').map((para: string) => (
          <p set:html={para} />
        ))}
      </div>
    </div>
    <div class="lg:col-span-2">
      <div 
        class="relative p-3 border border-[#c5a059]/30 rounded h-full cursor-pointer group"
        data-lightbox={ASSETS.photos[1].url}
        data-lightbox-alt="Elena Aker"
      >
        <img
          src={ASSETS.photos[1].url}
          srcset={isProd ? getResponsiveSrcSet(ASSETS.photos[1].url, [480, 768], ASSETS.photos[1].width) : undefined}
          alt="Elena Aker"
          width={600}
          height={750}
          loading="lazy"
          decoding="async"
          sizes={isProd ? "(min-width: 1024px) 34vw, 92vw" : undefined}
          class="w-full h-full object-cover shadow-2xl transition-transform duration-500 group-hover:scale-[1.02]"
        />
        <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
          <svg class="w-10 h-10 text-white/70" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>
        <div class="absolute -bottom-8 -right-8 bg-[#c5a059] text-black px-6 py-3 hidden md:block">
          <span class="text-[11px] font-bold uppercase tracking-[0.2em] font-subtitle">{t.badge}</span>
        </div>
      </div>
    </div>
  </div>

  {/* Subsections */}
  <div class="max-w-6xl mx-auto space-y-16 md:space-y-24">
    {bioSections.map((section, i) => {
      const isImageLeft = i % 2 === 0;
      return (
        <div
          class={`flex flex-col ${isImageLeft ? 'md:flex-row-reverse' : 'md:flex-row'} gap-8 md:gap-14 items-center`}
        >
          {/* Text Side */}
          <div class="flex-1">
            <h3 class="text-xl md:text-2xl font-display font-light mb-4 text-white tracking-wide">{section.heading}</h3>
            <div class="text-gray-400 font-light text-base md:text-lg leading-relaxed bio-text border-l border-[#c5a059]/20 pl-6">
              {section.text.split('\n\n').map((p: string) => (
                <p class="mb-4" set:html={p} />
              ))}
            </div>
          </div>
          
          {/* Image Side */}
          <div class="w-full md:w-64 lg:w-96 flex-shrink-0">
            <div 
              class="relative p-2 border border-[#c5a059]/30 rounded overflow-hidden cursor-pointer group bg-[#111]"
              data-lightbox={section.photo.url}
              data-lightbox-alt={section.photo.alt}
            >
              <img
                src={section.photo.url}
                srcset={isProd ? getResponsiveSrcSet(section.photo.url, [480, 768], section.photo.width) : undefined}
                alt={section.photo.alt}
                width={section.photo.width}
                height={section.photo.height}
                loading="lazy"
                decoding="async"
                sizes={isProd ? "(min-width: 1024px) 24rem, (min-width: 768px) 16rem, 100vw" : undefined}
                class="w-full h-auto max-h-[450px] object-cover shadow-lg rounded-sm transition-transform duration-500 group-hover:scale-[1.03]"
              />
              <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                <svg class="w-8 h-8 text-white/70" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </div>
            </div>
          </div>
        </div>
      );
    })}
  </div>
</section>
