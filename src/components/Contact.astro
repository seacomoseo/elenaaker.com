---
import { translations, Language } from '../translations';
import { CONTACT_INFO, ASSETS } from '../constants';
const { lang } = Astro.props as { lang: Language };
const t = translations[lang].contact;
---
<section id="contact" class="deferred-section py-24 md:py-32 px-6 md:px-24 bg-[#0a0a0a]">
  <div class="max-w-6xl mx-auto grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
    <div>
      <h2 class="text-4xl md:text-5xl font-display font-light mb-12 text-[#c5a059]">{t.title}</h2>
      <div class="space-y-10">
        <div>
          <p class="text-[10px] uppercase tracking-[0.4em] font-extrabold text-gray-500 mb-3">Email</p>
          <a 
            href={`mailto:${CONTACT_INFO.email}`} 
            class="text-xl md:text-2xl font-light text-white hover:text-[#c5a059] transition-colors truncate block"
          >
            {CONTACT_INFO.email}
          </a>
        </div>
        <div>
          <p class="text-[10px] uppercase tracking-[0.4em] font-extrabold text-gray-500 mb-3">{lang === Language.ES ? 'Teléfono' : 'Phone'}</p>
          <a 
            href={`tel:${CONTACT_INFO.phone}`} 
            class="text-xl md:text-2xl font-light text-white hover:text-[#c5a059] transition-colors"
          >
            {CONTACT_INFO.phone}
          </a>
        </div>
      </div>
    </div>

    <div class="flex items-center justify-center">
      <img
        src={ASSETS.bookingImg}
        alt="Elena Aker — Contratación"
        width={600}
        height={800}
        loading="lazy"
        decoding="async"
        class="w-full max-w-md rounded-lg shadow-2xl border border-white/5"
      />
    </div>
  </div>
</section>
