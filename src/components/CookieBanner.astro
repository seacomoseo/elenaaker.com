---
import { Language } from '../translations';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;

const t = {
  es: {
    text: 'Utilizamos cookies analíticas anónimas.',
    accept: 'Aceptar',
    decline: 'Rechazar',
    policy: 'Política de Cookies',
    link: '/politica-cookies'
  },
  en: {
    text: 'We use anonymous analytical cookies.',
    accept: 'Accept',
    decline: 'Decline',
    policy: 'Cookies Policy',
    link: '/en/cookies-policy'
  }
}[lang === Language.EN ? 'en' : 'es'];
---

<div id="cookie-banner" class="fixed bottom-0 md:bottom-4 left-0 md:left-4 right-0 md:right-auto z-50 p-2 md:p-3 bg-black/95 backdrop-blur-md border-t md:border-t-0 md:border border-[#c5a059]/30 md:rounded-sm text-white shadow-2xl w-full md:w-auto flex flex-row items-center justify-between gap-3 safe-area-pb hidden transition-opacity duration-500">
  <div class="text-[10px] font-light text-gray-300 leading-none">
    <span class="mr-1">{t.text}{' '}</span>
    <a href={t.link} class="text-[#c5a059] hover:underline whitespace-nowrap">
      {t.policy}
    </a>
  </div>
  <div class="flex flex-row gap-1.5 flex-shrink-0">
    <button
      id="cookie-decline"
      class="px-2 py-1.5 text-[9px] uppercase tracking-widest text-gray-400 hover:text-white transition-colors leading-none"
    >
      {t.decline}
    </button>
    <button
      id="cookie-accept"
      class="px-3 py-1.5 text-[9px] uppercase tracking-widest text-[#0a0a0a] bg-[#c5a059] hover:bg-[#e5c079] transition-colors rounded-sm leading-none"
    >
      {t.accept}
    </button>
  </div>
</div>

<script>
  const banner = document.getElementById('cookie-banner');
  const acceptBtn = document.getElementById('cookie-accept');
  const declineBtn = document.getElementById('cookie-decline');
  const consentKey = 'cookieConsent';
  const gaMeasurementId = 'G-DCQJWMM25F';
  let analyticsLoaded = false;

  function loadGA4() {
    if (analyticsLoaded || document.getElementById('ga4-script')) return;
    window[`ga-disable-${gaMeasurementId}`] = false;

    const script1 = document.createElement('script');
    script1.id = 'ga4-script';
    script1.async = true;
    script1.src = `https://www.googletagmanager.com/gtag/js?id=${gaMeasurementId}`;
    document.head.appendChild(script1);

    const script2 = document.createElement('script');
    script2.innerHTML = `
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('consent', 'default', {
        analytics_storage: 'granted'
      });
      gtag('config', '${gaMeasurementId}');
    `;
    document.head.appendChild(script2);
    analyticsLoaded = true;
  }

  function disableGA4() {
    window[`ga-disable-${gaMeasurementId}`] = true;

    if (typeof window.gtag === 'function') {
      window.gtag('consent', 'update', {
        analytics_storage: 'denied',
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
      });
    }

    document.cookie = `_ga=; Max-Age=0; path=/; domain=${location.hostname}`;
    document.cookie = `_ga_${gaMeasurementId.replace(/-/g, '')}=; Max-Age=0; path=/; domain=${location.hostname}`;
  }

  function init() {
    const consent = localStorage.getItem(consentKey);

    if (consent === 'accepted') {
      loadGA4();
    } else {
      disableGA4();
    }

    if (!consent) {
      banner?.classList.remove('hidden');
    }
  }

  acceptBtn?.addEventListener('click', () => {
    localStorage.setItem(consentKey, 'accepted');
    banner?.classList.add('hidden');
    loadGA4();
  });

  declineBtn?.addEventListener('click', () => {
    localStorage.setItem(consentKey, 'declined');
    banner?.classList.add('hidden');
    disableGA4();
  });

  // Run on load
  init();
</script>
