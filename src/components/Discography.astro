---
import { translations, Language } from '../translations';
import { ASSETS, ALBUMS } from '../constants';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = translations[lang].albums;

const PlatformIcons = {
  spotify: '#icon-spotify',
  apple: '#icon-apple',
  amazon: '#icon-amazon',
  deezer: '#icon-deezer',
  youtube: '#icon-yt',
  youtubeMusic: '#icon-yt-music',
};
---

<div id="video-container" class="w-full relative flex items-center justify-center bg-black md:min-h-[500px]">
  <img 
    src={ASSETS.videoPoster} 
    alt="Elena Aker performing" 
    width="1920" 
    height="1080" 
    id="video-poster"
    class="relative z-0 w-full h-auto object-cover" 
  />
  <div class="absolute top-0 left-0 right-0 z-20 h-[15%] pointer-events-none bg-gradient-to-b from-[#0a0a0a] to-transparent"></div>
  <div class="absolute bottom-0 left-0 right-0 z-20 h-[15%] pointer-events-none bg-gradient-to-t from-white to-transparent"></div>
</div>

<section id="albums" class="relative py-24 md:py-32 overflow-hidden bg-white">
  <div class="relative z-10">
    <div class="max-w-7xl mx-auto px-6 md:px-24">
      <div class="flex items-end justify-between mb-16 md:mb-20">
        <div>
          <span class="text-[11px] uppercase tracking-[0.4em] text-[#6f5524] mb-4 block">{lang === Language.ES ? 'Catálogo' : 'Catalog'}</span>
          <h2 class="text-4xl md:text-5xl font-display font-light text-black">{t.title}</h2>
        </div>
        <div id="albums-controls" class="items-center space-x-3" style="display: none;">
          <button
            id="albums-prev"
            type="button"
            class="w-10 h-10 rounded-full border border-[#c5a059] text-[#c5a059] flex items-center justify-center transition-all hover:bg-[#c5a059] hover:text-white"
            aria-label="Previous album"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M15 19l-7-7 7-7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <button
            id="albums-next"
            type="button"
            class="w-10 h-10 rounded-full border border-[#c5a059] text-[#c5a059] flex items-center justify-center transition-all hover:bg-[#c5a059] hover:text-white"
            aria-label="Next album"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
        </div>
      </div>
    </div>

    <div
      id="albums-scroll"
      class="flex overflow-x-auto gap-8 pb-10 snap-x snap-mandatory no-scrollbar scroll-smooth"
      style="scrollbar-width: none; -ms-overflow-style: none; scroll-padding: 0 2rem; padding-left: max(1.5rem, calc((100vw - 80rem) / 2 + 6rem)); padding-right: max(1.5rem, calc((100vw - 80rem) / 2 + 6rem));"
    >
      {ALBUMS.map((album) => (
        <div class="flex-shrink-0 w-[280px] sm:w-[320px] snap-center group bg-gray-50 p-6 border border-gray-200 rounded-lg hover:border-[#c5a059]/40 hover:shadow-xl transition-all">
          <div class="relative overflow-hidden aspect-square mb-6 shadow-2xl rounded group/img">
            <img
              src={album.image}
              alt={album.title}
              width="400"
              height="400"
              loading="lazy"
              decoding="async"
              class="w-full h-full object-cover group-hover/img:scale-110 transition-transform duration-1000"
            />
            <div class="absolute inset-0 bg-black/60 backdrop-blur-[12px] opacity-0 group-hover:opacity-100 transition-all duration-500 flex flex-col items-center justify-center p-6 text-center border border-white/10">
              <span class="text-[11px] font-bold text-[#c5a059] uppercase tracking-[0.4em] mb-8">{t.available}</span>
              <div class="grid grid-cols-3 gap-5">
                {Object.entries(album.links).map(([platform, url]) => (
                  <a
                    href={url as string}
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={`Listen on ${platform}`}
                    class="flex flex-col items-center gap-2 text-white/40 hover:text-white transition-all transform hover:scale-110 group/icon"
                  >
                    <div class="p-3 rounded-full bg-white/5 border border-white/10 group-hover/icon:bg-[#c5a059] group-hover/icon:text-black group-hover/icon:border-[#c5a059] transition-all">
                      <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                        <use href={(PlatformIcons as any)[platform]} />
                      </svg>
                    </div>
                    <span class="text-[8px] uppercase tracking-[0.2em] font-bold opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap text-[#c5a059]">
                      {platform === 'youtubeMusic' ? 'YT Music' : platform}
                    </span>
                  </a>
                ))}
              </div>
            </div>
          </div>
          <h3 class="text-xl font-display mb-2 text-black">{album.title}</h3>
          <p class="text-[11px] text-[#6f5524] uppercase tracking-widest">{album.artist}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<script define:vars={{ videoSrc: ASSETS.videoBg, videoSrcMobile: ASSETS.videoBgMobile, videoPoster: ASSETS.videoPoster }}>
  const container = document.getElementById('video-container');
  const poster = document.getElementById('video-poster');
  const albumScroll = document.getElementById('albums-scroll');
  const albumsControls = document.getElementById('albums-controls');
  const prevBtn = document.getElementById('albums-prev');
  const nextBtn = document.getElementById('albums-next');
  const interactiveElements = [
    ...(albumScroll ? Array.from(albumScroll.querySelectorAll('a, button')) : []),
    ...(prevBtn ? [prevBtn] : []),
    ...(nextBtn ? [nextBtn] : []),
  ];
  let videoInjected = false;
  let autoScrollTimer;
  let canAutoScroll = true;
  let inViewport = false;
  let isScrollable = false;
  let horizontalPadding = 0;
  let scrollStateFrame = 0;

  function updateHorizontalPadding() {
    if (!albumScroll) return;
    const styles = window.getComputedStyle(albumScroll);
    horizontalPadding = parseFloat(styles.paddingLeft || '0') + parseFloat(styles.paddingRight || '0');
  }

  function injectVideo() {
    if (!container || videoInjected) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const connection = navigator.connection || navigator.mozConnection || navigator.webkitConnection;
    if (connection?.saveData) return;
    
    const video = document.createElement('video');
    video.id = 'bg-video';
    video.src = window.matchMedia('(max-width: 767px)').matches ? videoSrcMobile : videoSrc;
    video.poster = videoPoster;
    video.muted = true;
    video.loop = true;
    video.playsInline = true;
    video.preload = 'none';
    video.className = 'absolute inset-0 z-10 h-full w-full object-cover';
    video.setAttribute('aria-label', 'Background performing video');
    
    container.appendChild(video);
    if (poster) {
      poster.style.opacity = '0';
      poster.style.transition = 'opacity 300ms ease';
    }
    scheduleScrollableStateUpdate();
    
    const videoObserver = new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting) video.play().catch(() => {});
      else video.pause();
    }, { threshold: 0.1 });
    
    videoObserver.observe(video);
    videoInjected = true;
  }

  const injectObserver = new IntersectionObserver(([entry]) => {
    if (entry.isIntersecting) {
      injectVideo();
      injectObserver.disconnect();
    }
  }, { rootMargin: '200px' });

  if (container && 'IntersectionObserver' in window) {
    injectObserver.observe(container);
  } else {
    injectVideo();
  }

  function moveCarousel(direction) {
    if (!albumScroll) return;
    const step = Math.max(Math.round(albumScroll.clientWidth * 0.85), 280);
    const { scrollLeft, scrollWidth, clientWidth } = albumScroll;
    const maxScrollLeft = scrollWidth - clientWidth;

    if (direction === 'left') {
      if (scrollLeft <= 40) {
        albumScroll.scrollTo({ left: maxScrollLeft, behavior: 'smooth' });
      } else {
        albumScroll.scrollBy({ left: -step, behavior: 'smooth' });
      }
    } else {
      if (scrollLeft >= maxScrollLeft - 40) {
        albumScroll.scrollTo({ left: 0, behavior: 'smooth' });
      } else {
        albumScroll.scrollBy({ left: step, behavior: 'smooth' });
      }
    }
  }

  function updateScrollableState() {
    if (!albumScroll || !albumsControls) return;
    const contentWidth = albumScroll.scrollWidth - horizontalPadding;

    isScrollable = contentWidth - albumScroll.clientWidth > 8;
    albumsControls.style.display = isScrollable ? 'flex' : 'none';
    prevBtn?.toggleAttribute('disabled', !isScrollable);
    nextBtn?.toggleAttribute('disabled', !isScrollable);
    updateAutoScroll();
  }

  function scheduleScrollableStateUpdate() {
    if (scrollStateFrame) window.cancelAnimationFrame(scrollStateFrame);
    scrollStateFrame = window.requestAnimationFrame(() => {
      scrollStateFrame = 0;
      updateScrollableState();
    });
  }

  function stopAutoScroll() {
    if (autoScrollTimer) {
      window.clearInterval(autoScrollTimer);
      autoScrollTimer = undefined;
    }
  }

  function updateAutoScroll() {
    const isHovered = albumScroll?.matches(':hover') || false;
    const hasFocus = interactiveElements.some((element) => element.matches(':focus, :focus-visible, :focus-within, :hover'));
    const shouldRun = isScrollable && inViewport && canAutoScroll && !isHovered && !hasFocus;

    if (shouldRun) {
      if (!autoScrollTimer) {
        autoScrollTimer = window.setInterval(() => moveCarousel('right'), 5000);
      }
      return;
    }

    stopAutoScroll();
  }

  prevBtn?.addEventListener('click', () => {
    canAutoScroll = false;
    stopAutoScroll();
    moveCarousel('left');
  });
  nextBtn?.addEventListener('click', () => {
    canAutoScroll = false;
    stopAutoScroll();
    moveCarousel('right');
  });

  albumScroll?.addEventListener('mouseenter', updateAutoScroll);
  albumScroll?.addEventListener('mouseleave', () => {
    canAutoScroll = true;
    updateAutoScroll();
  });
  interactiveElements.forEach((element) => {
    element.addEventListener('focus', updateAutoScroll, true);
    element.addEventListener('blur', () => {
      canAutoScroll = true;
      updateAutoScroll();
    }, true);
    element.addEventListener('mouseenter', updateAutoScroll);
    element.addEventListener('mouseleave', () => {
      canAutoScroll = true;
      updateAutoScroll();
    });
  });

  const scrollObserver = new IntersectionObserver(([entry]) => {
    inViewport = entry.isIntersecting;
    updateAutoScroll();
  }, { threshold: 0.1 });

  if (albumScroll) scrollObserver.observe(albumScroll);
  updateHorizontalPadding();
  window.addEventListener('resize', () => {
    updateHorizontalPadding();
    scheduleScrollableStateUpdate();
  });
  window.addEventListener('load', () => {
    updateHorizontalPadding();
    scheduleScrollableStateUpdate();
  });
  if ('ResizeObserver' in window && albumScroll) {
    const resizeObserver = new ResizeObserver(() => {
      updateHorizontalPadding();
      scheduleScrollableStateUpdate();
    });
    resizeObserver.observe(albumScroll);
  }

  scheduleScrollableStateUpdate();
</script>
