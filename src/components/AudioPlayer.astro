---
import { translations, Language } from '../translations';
import { ASSETS } from '../constants';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = translations[lang].audioPlayer;
---

<div id="audio-player-container" class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50 inline-flex items-center bg-black/80 border border-white/10 rounded-full pr-5 py-2 pl-2 shadow-2xl backdrop-blur-md w-auto max-w-[calc(100vw-3rem)]">
  <audio id="global-audio" preload="none" loop></audio>
  <button
    id="audio-toggle"
    class="w-10 h-10 min-w-[40px] flex items-center justify-center rounded-full bg-[#c5a059] text-black hover:bg-white transition-all transform hover:scale-105 mr-3"
    aria-label="Toggle music"
  >
    <svg id="play-icon" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
    <svg id="pause-icon" class="w-4 h-4 hidden" fill="currentColor" viewBox="0 0 24 24"><path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/></svg>
  </button>
  <div class="flex flex-col min-w-0">
    <span class="text-[10px] uppercase tracking-widest font-bold text-[#c5a059] truncate flex items-center gap-1">
      {t.label}
      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3" /></svg>
    </span>
    <span class="text-[11px] text-gray-400 font-light truncate">{t.track}</span>
  </div>
</div>

<script define:vars={{ audioSrc: ASSETS.audio, audioSrcMobile: ASSETS.audio.replace('.mp3', '-low.mp3') }}>
  const audio = document.getElementById('global-audio');
  const toggleBtn = document.getElementById('audio-toggle');
  const playIcon = document.getElementById('play-icon');
  const pauseIcon = document.getElementById('pause-icon');
  
  let isPlaying = false;
  let srcInjected = false;

  function injectAndPlay() {
    if (!audio) return;
    if (!srcInjected) {
      audio.src = window.innerWidth < 768 ? audioSrcMobile : audioSrc;
      srcInjected = true;
    }
    
    isPlaying = !isPlaying;
    if (isPlaying) {
      audio.play().catch(() => {
        isPlaying = false;
        updateIcons();
      });
    } else {
      audio.pause();
    }
    updateIcons();
  }

  function updateIcons() {
    if (isPlaying) {
      playIcon?.classList.add('hidden');
      pauseIcon?.classList.remove('hidden');
    } else {
      playIcon?.classList.remove('hidden');
      pauseIcon?.classList.add('hidden');
    }
  }

  toggleBtn?.addEventListener('click', injectAndPlay);

  // Initialize icon state
  updateIcons();
</script>
